# Database
DATABASE_URL=postgresql+asyncpg://vscx:your-password@postgres:5432/vscx

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1

# Security - REQUIRED: Must be changed in production
SECRET_KEY=your-super-secret-key-min-32-chars-random

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Allow scanning private IP ranges (not recommended for production)
ALLOW_PRIVATE_TARGETS=false

# AI Services (optional)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# NVD API (optional, for vulnerability enrichment)
NVD_API_KEY=
