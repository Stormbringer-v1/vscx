# Database
POSTGRES_USER=vscx
POSTGRES_PASSWORD=your-secure-password
POSTGRES_DB=vscx

# Backend Database URL (used by alembic and app)
DATABASE_URL=postgresql+asyncpg://vscx:your-secure-password@postgres:5432/vscx

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1

# Security
SECRET_KEY=your-super-secret-key-min-32-chars-random

# AI Services (optional)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# NVD API (optional, for vulnerability enrichment)
NVD_API_KEY=
